# ── Supabase credentials for the OUR MEMORIES gallery ──────────────────────
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy the "Project URL" and the "anon public" key
# 3. Copy this file to ".env"  (cp .env.example .env)  and paste your values
# 4. Run the SQL in  supabase/setup.sql  to create + seed the "memories" table
#
# NOTE: Vite only exposes variables that start with VITE_ to the browser.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
